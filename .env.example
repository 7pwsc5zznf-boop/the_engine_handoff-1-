# =============================================================================
# The Engine - Environment Variables
# =============================================================================
# This project currently requires NO environment variables to build or run.
# The contact form uses a client-side mailto: link and needs no secrets.
#
# Copy this file to `.env.local` only if/when you adopt the optional
# integrations below (see DEPLOYMENT.md "Contact Form" and "Phase 2" notes).
# Any variable that must be readable in the browser MUST be prefixed
# NEXT_PUBLIC_.
# -----------------------------------------------------------------------------

# Public site URL (used for canonical/OG metadata). Optional.
# NEXT_PUBLIC_SITE_URL=https://hdhp-theengine.com

# --- Phase 2: backend email service (OPTIONAL, not yet wired up) -------------
# If you later replace the mailto: form with a real email backend
# (e.g. Resend, SendGrid, Postmark), add the relevant key here.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=jeff@hdhp-theengine.com
